from flask import Flask, render_template, request
import tensorflow as tf
import numpy as np
from tensorflow.keras.preprocessing import image
from tensorflow.keras import backend as K
import os
import cv2

app = Flask(__name__)

# Load model
model = tf.keras.models.load_model(
    "model/tomato_disease_model.h5",
    custom_objects={'K': K}
)

class_names = [
    'Tomato_Bacterial_spot',
    'Tomato_Early_blight',
    'Tomato_Late_blight',
    'Tomato_Leaf_Mold',
    'Tomato_Septoria_leaf_spot',
    'Tomato_Spider_mites_Two_spotted_spider_mite',
    'Tomato_Target_Spot',
    'Tomato_Tomato_Yellow_Leaf_Curl_Virus',
    'Tomato_Tomato_mosaic_virus',
    'Tomato_healthy'
]

recommendations = {
    "Tomato_Bacterial_spot": "Apply copper-based fungicide and remove infected leaves.",
    "Tomato_Early_blight": "Use fungicides and practice crop rotation.",
    "Tomato_Late_blight": "Use protective fungicides and avoid overhead watering.",
    "Tomato_Leaf_Mold": "Use proper ventilation and fungicides.",
    "Tomato_Septoria_leaf_spot": "Remove affected leaves and use fungicides.",
    "Tomato_Spider_mites_Two_spotted_spider_mite": "Use neem oil or insecticidal soap.",
    "Tomato_Target_Spot": "Use copper fungicides and maintain proper spacing.",
    "Tomato_Tomato_Yellow_Leaf_Curl_Virus": "Control whiteflies and remove infected plants.",
    "Tomato_Tomato_mosaic_virus": "Use resistant varieties and remove infected plants.",
    "Tomato_healthy": "Your plant is healthy. Continue proper watering and fertilization."
}

# -------- GRAD-CAM FUNCTION --------
def make_gradcam_heatmap(img_array, model, last_conv_layer_name="Conv_1"):
    grad_model = tf.keras.models.Model(
        model.inputs,
        [model.get_layer(last_conv_layer_name).output, model.output]
    )

    with tf.GradientTape() as tape:
        conv_output, predictions = grad_model(img_array)
        loss = predictions[:, tf.argmax(predictions[0])]

    grads = tape.gradient(loss, conv_output)
    pooled_grads = tf.reduce_mean(grads, axis=(0, 1, 2))

    conv_output = conv_output[0]
    heatmap = conv_output @ pooled_grads[..., tf.newaxis]
    heatmap = tf.squeeze(heatmap)

    heatmap = np.maximum(heatmap, 0)
    heatmap /= np.max(heatmap)
    return heatmap


@app.route("/", methods=["GET", "POST"])
def index():
    prediction = None
    message = ""
    image_path = None
    cam_path = None

    if request.method == "POST":
        file = request.files["image"]

        # Save uploaded image
        image_path = os.path.join("static/uploads", file.filename)
        file.save(image_path)

        # Preprocess
        img = image.load_img(image_path, target_size=(224, 224))
        img_array = image.img_to_array(img) / 255.0
        img_array = np.expand_dims(img_array, axis=0)

        # Prediction
        preds = model.predict(img_array)
        idx = np.argmax(preds)
        prediction = class_names[idx]
        message = recommendations[prediction]

        # Grad-CAM
        heatmap = make_gradcam_heatmap(img_array, model)
        heatmap = cv2.resize(heatmap, (224, 224))
        heatmap = np.uint8(255 * heatmap)
        heatmap = cv2.applyColorMap(heatmap, cv2.COLORMAP_JET)

        original = cv2.imread(image_path)
        original = cv2.resize(original, (224, 224))
        cam_image = cv2.addWeighted(original, 0.6, heatmap, 0.4, 0)

        cam_path = os.path.join("static/cam", "cam_" + file.filename)
        cv2.imwrite(cam_path, cam_image)

    return render_template(
        "index.html",
        prediction=prediction,
        message=message,
        image_path=image_path,
        cam_path=cam_path
    )


if __name__ == "__main__":
    app.run(debug=True)
